{
    "name": "atoma-observability",
    "version": "0.0.0",
    "type": "module",
    "description": "Atoma observability runtime and types",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "source": "./src/index.ts"
        }
    },
    "imports": {
        "#observability": "./src/index.ts",
        "#observability/*": "./src/*"
    },
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@opentelemetry/api": "^1.9.0",
        "@opentelemetry/core": "^1.30.1",
        "@opentelemetry/sdk-trace-base": "^1.30.1",
        "atoma-shared": "workspace:*",
        "atoma-types": "workspace:*",
        "p-queue": "^6.6.2",
        "p-retry": "^7.1.1",
        "pino": "^9.4.0",
        "quick-lru": "^7.3.0"
    }
}
