{
    "name": "@atoma-js/observability",
    "version": "0.0.1",
    "type": "module",
    "description": "Atoma observability runtime and types",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "source": "./src/index.ts"
        }
    },
    "imports": {
        "#observability": "./src/index.ts",
        "#observability/*": "./src/*"
    },
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@atoma-js/shared": "workspace:*",
        "@atoma-js/types": "workspace:*",
        "quick-lru": "^7.3.0"
    }
}
