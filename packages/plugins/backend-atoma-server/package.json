{
    "name": "@atoma-js/backend-atoma-server",
    "version": "0.0.4",
    "type": "module",
    "description": "Atoma server backend plugin (optional)",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@atoma-js/backend-http": "workspace:*",
        "@atoma-js/backend-shared": "workspace:*",
        "@atoma-js/shared": "workspace:*",
        "@atoma-js/types": "workspace:*"
    }
}
