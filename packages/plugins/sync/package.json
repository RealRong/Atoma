{
    "name": "@atoma-js/sync",
    "version": "0.0.1",
    "type": "module",
    "description": "Atoma Sync Engine (optional extension package)",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "imports": {
        "#sync/*": "./src/*"
    },
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@atoma-js/atoma": "workspace:*",
        "@atoma-js/client": "workspace:*",
        "@atoma-js/core": "workspace:*",
        "@atoma-js/runtime": "workspace:*",
        "@atoma-js/shared": "workspace:*",
        "@atoma-js/types": "workspace:*",
        "rxdb": "^16.20.0"
    }
}
