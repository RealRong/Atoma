{
    "name": "@atoma-js/backend-shared",
    "version": "0.0.4",
    "type": "module",
    "description": "Shared backend helpers for Atoma optional backend plugins",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "source": "./src/index.ts"
        }
    },
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@atoma-js/core": "workspace:*",
        "@atoma-js/shared": "workspace:*",
        "@atoma-js/types": "workspace:*"
    }
}
