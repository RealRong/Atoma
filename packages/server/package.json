{
    "name": "@atoma-js/server",
    "version": "0.0.1",
    "type": "module",
    "description": "Atoma server handlers + adapters (optional)",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./adapters": {
            "types": "./dist/adapters/index.d.ts",
            "import": "./dist/adapters/index.js"
        },
        "./adapters/prisma": {
            "types": "./dist/adapters/prisma/index.d.ts",
            "import": "./dist/adapters/prisma/index.js"
        }
    },
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "check:layering": "node scripts/checkLayering.mjs"
    },
    "dependencies": {
        "@atoma-js/atoma": "workspace:*",
        "@atoma-js/shared": "workspace:*"
    },
    "peerDependencies": {
        "@prisma/client": "^5.0.0"
    },
    "peerDependenciesMeta": {
        "@prisma/client": {
            "optional": true
        }
    }
}
