{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "emitDeclarationOnly": true,
        "declaration": true,
        "declarationMap": true,
        "rootDir": "src",
        "outDir": "dist",
        "baseUrl": ".",
        "paths": {
            "@atoma-js/shared": [
                "../shared/dist/index.d.ts"
            ],
            "@atoma-js/types/shared": [
                "src/shared/index.ts"
            ],
            "@atoma-js/types/core": [
                "src/core/index.ts"
            ],
            "@atoma-js/types/runtime": [
                "src/runtime/index.ts"
            ],
            "@atoma-js/types/client": [
                "src/client/index.ts"
            ],
            "@atoma-js/types/client/sync": [
                "src/client/sync.ts"
            ],
            "@atoma-js/types/history": [
                "src/history/index.ts"
            ],
            "@atoma-js/types/protocol": [
                "src/protocol/index.ts"
            ],
            "@atoma-js/types/tools": [
                "src/tools/index.ts"
            ],
            "@atoma-js/types/observability": [
                "src/observability/index.ts"
            ],
            "@atoma-js/types/sync": [
                "src/sync/index.ts"
            ],
            "@atoma-js/types/devtools": [
                "src/devtools/index.ts"
            ],
            "@atoma-js/types/internal": [
                "src/internal/index.ts"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.ts",
        "**/*.spec.ts"
    ]
}
