{
    "name": "@atoma-js/client",
    "version": "0.0.1",
    "type": "module",
    "description": "Atoma client runtime and plugins",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "source": "./src/index.ts"
        }
    },
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@atoma-js/runtime": "workspace:*",
        "@atoma-js/shared": "workspace:*",
        "@atoma-js/types": "workspace:*"
    }
}
