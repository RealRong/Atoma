{
    "name": "@atoma-js/atoma",
    "version": "1.0.2",
    "type": "module",
    "description": "Atomic state management with universal persistence",
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/RealRong/Atoma.git",
        "directory": "packages/atoma"
    },
    "bugs": {
        "url": "https://github.com/RealRong/Atoma/issues"
    },
    "homepage": "https://github.com/RealRong/Atoma/tree/main/packages/atoma#readme",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev:lib": "tsup --watch",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@atoma-js/client": "workspace:*",
        "@atoma-js/types": "workspace:*"
    }
}
